{
  "name": "@hermetic/runtime",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:browser": "vitest run --browser.name=chromium"
  },
  "files": ["dist"],
  "dependencies": {
    "@hermetic/core": "workspace:*",
    "@hermetic/fs": "workspace:*",
    "@hermetic/net": "workspace:*",
    "@hermetic/vm": "workspace:*",
    "@hermetic/dev": "workspace:*",
    "@hermetic/pm": "workspace:*",
    "@hermetic/proc": "workspace:*",
    "@hermetic/shell": "workspace:*"
  }
}
